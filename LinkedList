    }
    
}


//class Linkedlist 
public class SLinkedList<T> {

    private SNode head;
    private SNode tail;
    private int size = 0;
    //addLast,AddFirst,

    public int size() {
        return size;
    }
    
           
       public void addLast(T element) 
       {
        SNode temp = new SNode();
        if (size==0) {
            this.addFirst( element);
        } else {
            temp.data=element;
            tail.next=temp;
            tail=temp;
        }
        size++;
    
    }

    public void addFirst(T element) {

        SNode temp = new SNode();
        temp.data = element;
        temp.next = head;
        head = temp;
        size++;
     if (tail == null)tail=head=temp;

    }
public void addAtIndex(int index, T element) {
        if(index<1||index>size+1)System.out.println("exption out of bound  ");

       
        else {
            if (index == 1) {
                addFirst(element);
            } else if (index == size+1) {
                addLast(element);
            } else {
                SNode curr = head;
                SNode temp=new SNode();
                for (int i = 1; i < index -1; i++) {
                    
                   //1 2 3 4 6
                   // System.out.println(curr.data);
                    curr = curr.next;
                    
                }
                temp.data=element;
                temp.next=curr.next;
                curr.next=temp;
                size++;
                
            }
        }
    }
public void removeFirst()
{
    head=head.next;
}
public void removeLast()
{
    SNode current=new SNode();
    current=head;
    for(int i=0;i<size-2;i++)
    {
        current=current.next;
       // System.out.print(i+" ");
    }
   current.next=null;
   tail=current;
   
    
}
public void remove(int index) {
        if (index == 1) {
           removeFirst();
        }
        else if (index==size)removeLast();
        else {
            // removing some element further down in the list;
            // traverse to the node before the one we want to remove
            SNode current = head;
            for (int i = 0; i < index - 1; i++) {
                current = current.next;
            }
            //1 2 3 4 5 
            // change its next pointer to skip past the offending node
            current.next = current.next.next;
        }
    }
